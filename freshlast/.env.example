# Copy to `.env` or `.env.local` in this folder and fill in values.
# FastAPI root (no trailing slash, no /api suffix — apiClient adds /api)
VITE_API_BASE_URL=http://127.0.0.1:8000

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Service role key stays on the server only (backend/app/.env SECRET_KEY). Do not put it in Vite.
